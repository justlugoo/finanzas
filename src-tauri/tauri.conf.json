{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finanzas",
  "version": "0.1.0",
  "identifier": "com.justlugoo.finanzas",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Finanzas",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "notification": { "all": true },
    "autostart": { "all": true }
  }
}
