{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FinCapX",
  "version": "1.1.0",
  "identifier": "com.justlugoo.finanzas",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FinCapX",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": ["icons/android-chrome-512x512.png"],
    "linux": {
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
